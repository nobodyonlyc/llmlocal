# Defaults below are for running the API natively (cargo run --bin server)
# against the containerized Qdrant/llama-server started by scripts/dev-up.sh.
# The containerized `api` service itself gets these from deploy/podman-compose.yml
# instead (service DNS names, not 127.0.0.1).
LLAMA_SERVER_URL=http://127.0.0.1:8080
QDRANT_URL=http://127.0.0.1:6334
DEFAULT_TOP_K=5
CHUNK_SIZE=800
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
